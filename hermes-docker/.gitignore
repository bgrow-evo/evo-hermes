# Generated by install.ps1 (contains the resolved HERMES_DATA host path)
.env

# In case anyone points the data dir here
.hermes/

# Codex OAuth runtime artifacts — may contain auth codes / token fragments
.codex-oauth/*.callback.txt
.codex-oauth/*.result.txt
**/.codex_callback.txt
**/.codex_pkce.json
**/.codex_result.txt
**/.codex_smoke.txt

# Microsoft Graph delegated token cache — contains refresh tokens (secrets)
**/.graph_user_token_cache.json
