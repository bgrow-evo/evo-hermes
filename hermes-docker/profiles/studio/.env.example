# Studio profile environment — TEMPLATE. Copy to `.env` and fill in.
#
# Secrets are allowed in the real `.env` (which is gitignored), never in any
# other file in this profile. install.ps1 injects OPENAI_API_KEY into the
# deployed copy (~/.hermes/profiles/studio/.env) from ~/.hermes/.env so the
# studio gateway can run its agent.
#
# Vendor DAM credentials: the Merch Sheet (SharePoint) is the live source of
# truth and passwords change frequently — verify before use.

# --- Arc'teryx Aprimo DAM ---
ARCTERYX_APRIMO_URL=https://arcteryx.aprimo.com/login/Account/Login
ARCTERYX_APRIMO_USERNAME=
ARCTERYX_APRIMO_PASSWORD=

# --- Amer Sports DAM ---
AMER_SPORTS_DAM_USERNAME=
AMER_SPORTS_DAM_PASSWORD=

# --- Mervin DAM: Bent Metal, Lib Tech, GNU ---
MERVIN_DAM_USERNAME=
MERVIN_DAM_PASSWORD=

# --- Sunski Elastic ---
SUNSKI_ELASTIC_USERNAME=
SUNSKI_ELASTIC_PASSWORD=
