# Compose environment for the hermes-docker stack.
# Copy to `.env` and fill in. install.ps1 writes/refreshes most of these for you
# (resolved HERMES_DATA host path + dashboard basic-auth credentials).
#
# This file is the COMPOSE config, not your secrets store. LLM API keys and Teams
# bot credentials live in ~/.hermes/.env (see README "Current credentials").

# Host directory bind-mounted to /opt/data (set by install.ps1).
HERMES_DATA=

# Dashboard web UI (chat) HTTP basic auth.
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=
HERMES_DASHBOARD_BASIC_AUTH_SECRET=

# --- Optional: used by teams-bot-setup.ps1 / ngrok, if you keep them here ---
# ngrok tunnel for the Teams webhook
NGROK_AUTHTOKEN=
# Azure bot registration (Teams)
CLIENT_ID=
CLIENT_SECRET=
TENANT_ID=
